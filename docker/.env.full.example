# Storewide Loss Prevention - Full Stack Environment Variables
# Copy to docker/.env and adjust values as needed.
#
# This file is used with docker-compose.full.yaml which runs
# SceneScape + Loss Prevention from pre-built Docker images.
#
# Run ./init.sh first — it auto-populates SECRETSDIR, SUPASS,
# DATABASE_PASSWORD, and CONTROLLER_AUTH.

# ---- SceneScape Secrets (auto-populated by init.sh) ----
SECRETSDIR=../scenescape/secrets
SUPASS=
DATABASE_PASSWORD=
CONTROLLER_AUTH=

# ---- SceneScape Image Versions ----
SCENESCAPE_REGISTRY=
SCENESCAPE_VERSION=v2026.0.0
DLSTREAMER_VERSION=2026.1.0-20260331-weekly-ubuntu24

# ---- Host ----
HOST_IP=
UID=1000
GID=1000

# ---- Proxy ----
http_proxy=
https_proxy=
HTTP_PROXY=
HTTPS_PROXY=
no_proxy=localhost,127.0.0.1
NO_PROXY=localhost,127.0.0.1

# ---- Store ----
STORE_NAME=Retail
STORE_ID=store_001

# ---- MQTT (auto-configured via SceneScape broker) ----
MQTT_HOST=broker.scenescape.intel.com
MQTT_PORT=1883

# ---- SeaweedFS ----
SEAWEEDFS_S3_PORT=8333
SEAWEEDFS_MASTER_PORT=9333
SEAWEEDFS_VOLUME_PORT=8080

# ---- External Services ----
BEHAVIORAL_ANALYSIS_URL=http://behavioral-analysis-service:8090
RULE_SERVICE_URL=http://rule-service:8091

# ---- LP Service ----
LP_SERVICE_PORT=8082
LOG_LEVEL=INFO

# ---- SceneScape API (zone auto-discovery) ----
SCENESCAPE_API_USER=admin
SCENESCAPE_API_PASSWORD=
