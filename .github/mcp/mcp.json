{
  "mcpServers": {
    "github": {
      "command": "docker",
      "args": [
        "run", "-i", "--rm",
        "-e", "GITHUB_PERSONAL_ACCESS_TOKEN",
        "ghcr.io/github/github-mcp-server"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "poi-system": {
      "command": "python",
      "args": ["-m", "mcp_server.server"],
      "cwd": "${workspaceRoot}/person-of-interest",
      "env": {
        "PYTHONPATH": "${workspaceRoot}/person-of-interest",
        "MCP_TRANSPORT": "stdio",
        "REDIS_HOST": "localhost",
        "REDIS_PORT": "6379",
        "POI_BACKEND_URL": "http://localhost:8000",
        "MQTT_HOST": "broker.scenescape.intel.com",
        "MQTT_PORT": "1883",
        "GITHUB_TOKEN": "${GITHUB_TOKEN}",
        "MCP_FILESYSTEM_ROOT": "${workspaceRoot}/person-of-interest",
        "MCP_ALLOW_MUTATIONS": "false",
        "LOG_LEVEL": "INFO"
      }
    }
  }
}
