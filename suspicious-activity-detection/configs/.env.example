# Storewide Loss Prevention - Environment Variables
#
# Edit values as needed, then run:
#         ./scenescape/scripts/init.sh        # populates secrets + scene fields
# init.sh reads this file and writes docker/.env (used by docker-compose).
# Never commit docker/.env — it contains auto-generated secrets.
#
# To override specific variables without running init.sh:
#         cp configs/.env.example docker/.env  && edit docker/.env

# ---- SceneScape Secrets (auto-populated by init.sh) ----
SECRETSDIR=./scenescape/secrets
SUPASS=<auto-generated>
DATABASE_PASSWORD=<auto-generated>
CONTROLLER_AUTH=<auto-generated>
UID=1000
GID=1000

# ---- Scene (auto-populated from zone_config.json by init.sh) ----
CAMERA_NAME=<auto-generated>
SCENE_ZIP=<auto-generated>
VIDEO_FILE=<auto-generated>
# STREAM_DENSITY is used by performance-tools (make stream-density), not by runtime services.
STREAM_DENSITY=<auto-generated>

# ---- OpenVINO Models (auto-generated by init.sh from DETECT_MODEL + REID_MODEL) ----
# MODELS=<auto-generated>
MODEL_PRECISION=FP32

# ---- SceneScape image versions ----
SCENESCAPE_REGISTRY=
SCENESCAPE_VERSION=2026.1.0-20260505-weekly
DLSTREAMER_VERSION=2026.1.0-ubuntu24-rc1

# ---- Host / Proxy ----
HOST_IP=
http_proxy=
https_proxy=
no_proxy=localhost,127.0.0.1

# ---- LP Service ----
LP_SERVICE_PORT=8082
LOG_LEVEL=INFO

# ---- Behavioral Analysis service ----
BA_SERVICE_PORT=8085
BA_MIN_FRAMES=10        # minimum frames before running pose/VLM analysis
BA_MAX_FRAMES=20        # maximum frames fetched per BA request
BA_POSE_FRAMES=10       # number of frames used for pose scoring
BA_CONFIDENCE=0.5       # keypoint confidence threshold
BA_GST_DEVICE=CPU       # inference device for GStreamer pipeline (CPU / GPU / NPU)
VLM_ENABLED=true

# ---- MQTT (SceneScape broker) ----
MQTT_HOST=broker.scenescape.intel.com
MQTT_PORT=1883
BA_REQUEST_TOPIC=ba/requests   # topic swlp-service writes BA frame requests to
BA_RESULT_TOPIC=ba/results     # topic behavioral-analysis publishes results to

# ---- SeaweedFS object storage ----
SEAWEEDFS_S3_PORT=8333
SEAWEEDFS_MASTER_PORT=9333
SEAWEEDFS_VOLUME_PORT=8080
SEAWEEDFS_FILER_PORT=8888

# ---- OVMS (VLM inference server) ports ----
OVMS_GRPC_PORT=8002
OVMS_REST_PORT=8003
# OVMS image tag: 2026.1-gpu (CPU,iGPU,dGPU,NPU) | 2026.1 (CPU only)
OVMS_IMAGE_TAG=2026.1-gpu

# ---- Alert Service ----
ALERT_SERVICE_PORT=8000
ALERT_SERVICE_URL=http://alert-service:8000

# ---- Behavioral Analysis URL (swlp-service → BA service) ----
BEHAVIORAL_ANALYSIS_URL=http://behavioral-analysis:8080
ANALYSIS_FPS=1          # frames per second sent for behavioral analysis

# ---- SceneScape API (for zone auto-discovery) ----
SCENESCAPE_API_USER=admin
SCENESCAPE_API_PASSWORD=<auto-generated>

# ---- Model download script only (download_models/model_download.sh) ----
# These variables are NOT passed to runtime containers. They control which
# model files are fetched during `make download-models`.
VLM_MODEL_NAME=Qwen/Qwen2.5-VL-7B-Instruct
VLM_PRECISION=int4
VLM_TIMEOUT=240
TARGET_DEVICE=GPU
YOLO_MODEL_NAME=yolo26n-pose
# ---- DLStreamer pipeline ----
# Device config is now in configs/res/all-gpu-cpu.env (default), all-gpu.env, or all-cpu.env
# Select via: make up DEVICE=all-gpu-cpu.env
DETECT_MODEL=yolo11s #person-detection-retail-0013
# Model-proc file: auto-derived (yolo* → yolo-v8.json, else {model}.json). Override if needed:
# DETECT_MODEL_PROC=person-detection-retail-0013.json
REID_MODEL=person-reidentification-retail-0277
# ---- Performance metrics results path ----
RESULTS_PATH=./results
