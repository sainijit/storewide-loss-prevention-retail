DECODE='rtph264depay ! h264parse ! vah264dec ! vapostproc ! video/x-raw'
MODEL_PRECISION=FP16
DETECT_MODEL_PRECISION=FP16-INT8
REID_MODEL_PRECISION=FP16-INT8
DETECT_DEVICE=NPU
PRE_PROCESS=pre-process-backend=ie
PRE_PROCESS_CONFIG=pre-process-config=resize_type=standard
# face-detection runs after personreid which outputs system memory, so use opencv
FACE_PRE_PROCESS=pre-process-backend=opencv
FACE_PRE_PROCESS_CONFIG=
DETECTION_OPTIONS="nireq=1"
REID_DEVICE=NPU
REID_PRE_PROCESS=pre-process-backend=opencv
REID_OPTIONS="nireq=2"
POST_DETECT=
POST_INFERENCE=""
QUEUE_OPTIONS='max-size-buffers=1 leaky=downstream'
DETECT_THRESHOLD=0.5
INFERENCE_INTERVAL=1
CLIP_REID_PRECISION=FP16
FACE_DETECTION_PRECISION=FP16
