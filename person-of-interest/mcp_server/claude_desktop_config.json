{
  "mcpServers": {
    "poi-system": {
      "command": "python",
      "args": ["-m", "mcp_server.server"],
      "cwd": "/path/to/person-of-interest",
      "env": {
        "PYTHONPATH": "/path/to/person-of-interest",
        "MCP_TRANSPORT": "stdio",
        "REDIS_HOST": "localhost",
        "REDIS_PORT": "6379",
        "POI_BACKEND_URL": "http://localhost:8000",
        "MQTT_HOST": "localhost",
        "MQTT_PORT": "1883",
        "GITHUB_TOKEN": "ghp_your_token_here",
        "JIRA_URL": "https://your-org.atlassian.net",
        "JIRA_USERNAME": "your.email@example.com",
        "JIRA_API_TOKEN": "your_jira_api_token",
        "MCP_FILESYSTEM_ROOT": "/path/to/person-of-interest",
        "MCP_ALLOW_MUTATIONS": "false",
        "LOG_LEVEL": "INFO"
      }
    }
  }
}
