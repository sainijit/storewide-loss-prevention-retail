# ── POI MCP Server — Environment Variables ───────────────────────────────────
#
# Copy to mcp_server/.env and fill in values.
# Never commit a file with real tokens or passwords.
#
# Usage:
#   cp mcp_server/.env.example mcp_server/.env
#   # Edit values, then:
#   docker compose up mcp-server

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_your_token_here
GITHUB_ORG=your-github-org

# ── Jira ──────────────────────────────────────────────────────────────────────
JIRA_URL=https://your-org.atlassian.net
JIRA_USERNAME=your.email@example.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_PROJECT_KEY=POI

# ── Filesystem sandbox root ───────────────────────────────────────────────────
# Path inside the container that file system tools are constrained to.
MCP_FILESYSTEM_ROOT=/app

# ── Redis (shared with POI backend) ──────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ── POI Backend URL (for FAISS/POI REST tools) ────────────────────────────────
POI_BACKEND_URL=http://poi-backend:8000

# ── MQTT / SceneScape ─────────────────────────────────────────────────────────
MQTT_HOST=broker.scenescape.intel.com
MQTT_PORT=1883
MQTT_CA_CERT=
SCENE_UID=bfb9f86b-b152-4e7f-8099-7c251ed84630
MQTT_EVENT_BUFFER_SIZE=100

# ── OpenVINO ──────────────────────────────────────────────────────────────────
MODEL_BASE=/models/intel
INFERENCE_DEVICE=CPU

# ── Docker (empty = use default socket /var/run/docker.sock) ─────────────────
DOCKER_BASE_URL=

# ── LLM — Large Language Model (OpenAI-compatible endpoint) ──────────────────
# Works with Ollama, vLLM, LM Studio, or the OpenAI API.
# In Docker Compose, use the service name as host (e.g. http://ollama:11434/v1).
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
# Leave blank to require explicit model= per call (use llm_list_models to discover).
LLM_MODEL=
# Request timeout in seconds
MCP_LLM_TIMEOUT=60

# ── VLM — Vision Language Model (OpenAI-compatible endpoint with vision) ──────
# Works with LLaVA/Ollama, GPT-4o, Qwen-VL, MiniCPM-V, etc.
VLM_BASE_URL=http://localhost:11434/v1
VLM_API_KEY=ollama
# Leave blank to require explicit model= per call (use vlm_list_models to discover).
VLM_MODEL=
# Request timeout in seconds (vision inference is slower than text)
MCP_VLM_TIMEOUT=120

# ── Security ──────────────────────────────────────────────────────────────────
# Set to "true" to enable write/mutation tools (file write, issue create, etc.)
MCP_ALLOW_MUTATIONS=false
# Set to "true" to allow LLM/VLM calls to non-local (remote) AI endpoints.
# Keep "false" when the endpoint is local Ollama to prevent accidental
# exfiltration of surveillance or biometric data.
MCP_ALLOW_EXTERNAL_AI=false

# Python sandbox execution timeout in seconds
MCP_PYTHON_EXEC_TIMEOUT=30

# ── Deep Learning ─────────────────────────────────────────────────────────────
# Set to "true" to allow DL model tools to access paths outside MODEL_BASE.
MCP_DL_ALLOW_ALL_PATHS=false

# ── MCP Transport ─────────────────────────────────────────────────────────────
# "stdio" for Claude Desktop / local use
# "streamable-http" for containerized deployment
MCP_TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=9000

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
