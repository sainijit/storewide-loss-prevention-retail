# ── POI Re-identification System Environment Configuration ──

# Tag
TAG=1.0.0

# ── SceneScape Configuration ────────────────────────────
SCENE_UID=bfb9f86b-b152-4e7f-8099-7c251ed84630
MQTT_HOST=broker.scenescape.intel.com
MQTT_PORT=1883
MQTT_TOPIC_EVENT=scenescape/event/${SCENE_UID}/objects
MQTT_CA_CERT=

# ── MQTT Mode ────────────────────────────────────────────
MQTT_MODE=embedded
MQTT_USERNAME=
MQTT_PASSWORD=

# ── SceneScape API ──────────────────────────────────────
SCENESCAPE_API_URL=https://10.223.23.34
SCENESCAPE_API_TOKEN=

# ── Redis ───────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
APPEARANCE_TTL_DAYS=7

# ── FAISS ───────────────────────────────────────────────
FAISS_DIMENSION=256
FAISS_INDEX_PATH=/data/faiss/poi.index
FAISS_ID_MAP_PATH=/data/faiss/id_map.json

# ── Matching ────────────────────────────────────────────
SIMILARITY_THRESHOLD=0.6
SEARCH_TOP_K=10

# ── OpenVINO Models ─────────────────────────────────────
MODEL_BASE=/models/intel
DET_MODEL=/models/intel/face-detection-retail-0004/FP32/face-detection-retail-0004.xml
INFERENCE_DEVICE=CPU

# ── API ─────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Alert / Delivery ───────────────────────────────────
ALERT_WEBHOOK_URL=
DELIVERY_HANDLERS=log,mqtt,websocket
CONFIG_PATH=config/config.yaml

# ── Cache ───────────────────────────────────────────────
OBJECT_CACHE_TTL=300
ALERT_DEDUP_TTL=300

# ── Logging ─────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Benchmark ───────────────────────────────────────────
BENCHMARK_LATENCY=false

# ── Proxy ───────────────────────────────────────────────
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1
