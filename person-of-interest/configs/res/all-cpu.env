DECODE='rtph264depay ! h264parse ! avdec_h264 ! videoconvert ! videorate ! video/x-raw,format=BGR,framerate=10/1'
MODEL_PRECISION=FP32
DETECT_MODEL_PRECISION=FP32
REID_MODEL_PRECISION=FP32
DETECT_DEVICE=CPU
PRE_PROCESS=pre-process-backend=opencv
PRE_PROCESS_CONFIG=pre-process-config=resize_type=standard
FACE_PRE_PROCESS=pre-process-backend=opencv
FACE_PRE_PROCESS_CONFIG=pre-process-config=resize_type=standard
DETECTION_OPTIONS="ie-config=CPU_THROUGHPUT_STREAMS=2 nireq=2"
REID_DEVICE=CPU
REID_PRE_PROCESS=pre-process-backend=opencv
REID_OPTIONS="ie-config=CPU_THROUGHPUT_STREAMS=2 nireq=2"
POST_DETECT=""
POST_INFERENCE='videoconvert ! video/x-raw,format=BGR'
QUEUE_OPTIONS='max-size-buffers=1 leaky=downstream'
DETECT_THRESHOLD=0.5
INFERENCE_INTERVAL=1