DECODE='rtph264depay ! h264parse ! vah264dec ! vapostproc ! video/x-raw(memory:VAMemory)'
MODEL_PRECISION=FP16
DETECT_MODEL_PRECISION=FP16
REID_MODEL_PRECISION=FP16
DETECT_DEVICE=GPU
PRE_PROCESS=pre-process-backend=va-surface-sharing
PRE_PROCESS_CONFIG=pre-process-config=resize_type=standard
# face-detection runs after personreid which outputs system memory, so use opencv (not va-surface-sharing)
FACE_PRE_PROCESS=pre-process-backend=opencv
FACE_PRE_PROCESS_CONFIG=
DETECTION_OPTIONS="ie-config=GPU_THROUGHPUT_STREAMS=2 nireq=2"
REID_DEVICE=GPU
REID_PRE_PROCESS=pre-process-backend=opencv
REID_OPTIONS="nireq=2"
POST_DETECT='vapostproc ! video/x-raw'
POST_INFERENCE=""
QUEUE_OPTIONS='max-size-buffers=1 leaky=downstream'
DETECT_THRESHOLD=0.5
INFERENCE_INTERVAL=1