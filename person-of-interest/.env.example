# ── POI Re-identification System Environment Configuration ──

# Tag
TAG=1.0.0

# ── SceneScape Configuration ────────────────────────────
# Leave SCENE_UID empty to auto-discover from the SceneScape API at startup.
# If multiple scenes exist, set this explicitly to select the desired scene.
SCENE_UID=
MQTT_HOST=broker.scenescape.intel.com
MQTT_PORT=1883
MQTT_TOPIC_EVENT=scenescape/data/camera/+
MQTT_CA_CERT=

# ── MQTT Mode ────────────────────────────────────────────
MQTT_MODE=embedded
MQTT_USERNAME=
MQTT_PASSWORD=

# ── SceneScape API ──────────────────────────────────────
# SceneScape web is always reachable at https://localhost (port 443 on the host).
# Change only if accessing SceneScape from a remote machine.
SCENESCAPE_API_URL=https://web.scenescape.intel.com
SCENESCAPE_API_TOKEN=

# ── SceneScape Docker Images ────────────────────────────
# Registry prefix for SceneScape images (leave empty for local/default registry)
SCENESCAPE_REGISTRY=
# SceneScape image version tag
SCENESCAPE_VERSION=

# ── Redis ───────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
APPEARANCE_TTL_DAYS=7

# ── FAISS ───────────────────────────────────────────────
FAISS_DIMENSION=256
FAISS_INDEX_PATH=/data/faiss/poi.index
FAISS_ID_MAP_PATH=/data/faiss/id_map.json

# ── Matching ────────────────────────────────────────────
# Online POI matching threshold (cosine similarity 0-1)
SIMILARITY_THRESHOLD=0.50
# Offline search threshold (cosine similarity 0-1)
SEARCH_SIMILARITY_THRESHOLD=0.60
SEARCH_TOP_K=10

# ── OpenVINO Models ─────────────────────────────────────
MODEL_BASE=/models/intel
DET_MODEL=/models/intel/face-detection-retail-0004/FP32/face-detection-retail-0004.xml
INFERENCE_DEVICE=CPU

# ── DLStreamer Pipeline (GPU by default) ─────────────────
# Device and precision for the DLStreamer inference pipeline.
# For CPU-only, use configs/res/all-cpu.env values instead.
MODEL_PRECISION=FP16
DETECT_MODEL_PRECISION=FP16
REID_MODEL_PRECISION=FP16
DETECT_DEVICE=GPU
REID_DEVICE=GPU
DECODE='rtph264depay ! h264parse ! vah264dec ! vapostproc ! video/x-raw(memory:VAMemory)'
PRE_PROCESS=pre-process-backend=va-surface-sharing
PRE_PROCESS_CONFIG=pre-process-config=resize_type=standard
FACE_PRE_PROCESS=pre-process-backend=opencv
FACE_PRE_PROCESS_CONFIG=
DETECTION_OPTIONS="ie-config=GPU_THROUGHPUT_STREAMS=2 nireq=2"
REID_PRE_PROCESS=pre-process-backend=opencv
REID_OPTIONS="nireq=2"
POST_DETECT='vapostproc ! video/x-raw'
POST_INFERENCE=""
QUEUE_OPTIONS='max-size-buffers=1 leaky=downstream'
DETECT_THRESHOLD=0.5
INFERENCE_INTERVAL=1

# ── API ─────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Camera / MediaMTX ──────────────────────────────────
# Comma-separated camera IDs for RTSP pre-warming
RTSP_PREWARM_CAMERAS=Camera_01,Camera_02
# Map camera_id to MediaMTX stream path (camera_id:stream_path,...)
CAMERA_STREAM_MAP=Camera_01:Camera_01,Camera_02:Camera_02
# Port for the MediaMTX WebRTC player (used by the UI to build stream URLs)
MEDIAMTX_WEBRTC_PORT=8889

# ── Alert / Delivery ───────────────────────────────────
ALERT_WEBHOOK_URL=
DELIVERY_HANDLERS=log,mqtt,websocket
CONFIG_PATH=config/config.yaml

# ── Cache ───────────────────────────────────────────────
OBJECT_CACHE_TTL=300
ALERT_DEDUP_TTL=300

# ── Logging ─────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Benchmark ───────────────────────────────────────────
BENCHMARK_LATENCY=false

# ── Proxy ───────────────────────────────────────────────
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1

# ── Host identity (set automatically by make init) ──────
# Used to run poi-backend as the host user so bind-mounted
# directories (e.g. results/) are written with correct ownership.
HOST_UID=1000
HOST_GID=1000
