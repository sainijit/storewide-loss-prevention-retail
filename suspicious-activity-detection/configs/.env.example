# Storewide Loss Prevention - Environment Variables
#
# Copy to configs/.env and adjust values as needed.
# Sensitive values (SUPASS, DATABASE_PASSWORD, CONTROLLER_AUTH) are
# auto-generated by init.sh. Never commit configs/.env.
#
# Usage:  cp configs/.env.example configs/.env
#         ./scripts/init.sh        # populates secrets + scene fields

# ---- SceneScape Secrets (auto-populated by init.sh) ----
SECRETSDIR=./scenescape/secrets
SUPASS=<auto-generated>
DATABASE_PASSWORD=<auto-generated>
CONTROLLER_AUTH=<auto-generated>
UID=1000
GID=1000

# ---- Scene (auto-populated from zone_config.json by init.sh) ----
SCENE_NAME=storewide loss prevention
CAMERA_NAME=lp-camera1

# ---- Infrastructure (edit here directly) ----
SCENE_ZIP=storewide-loss-prevention.zip
VIDEO_FILE=lp-camera1.mp4

# ---- OpenVINO Models (comma-separated) ----
MODELS=person-detection-retail-0013,person-reidentification-retail-0277
MODEL_PRECISION=FP32

# ---- SceneScape image versions ----
SCENESCAPE_REGISTRY=
SCENESCAPE_VERSION=v2026.0.0
DLSTREAMER_VERSION=2026.1.0-20260331-weekly-ubuntu24

# ---- Host / Proxy ----
HOST_IP=
http_proxy=
https_proxy=
no_proxy=localhost,127.0.0.1

# ---- Store ----
STORE_NAME=Retail
STORE_ID=store_001

# ---- LP Service ----
LP_SERVICE_PORT=8082
LOG_LEVEL=INFO

# ---- MQTT (SceneScape broker) ----
MQTT_HOST=broker.scenescape.intel.com
MQTT_PORT=1883

# ---- SeaweedFS ----
SEAWEEDFS_S3_PORT=8333
SEAWEEDFS_MASTER_PORT=9333
SEAWEEDFS_VOLUME_PORT=8080

# ---- SceneScape API (for zone auto-discovery) ----
SCENESCAPE_API_USER=admin
SCENESCAPE_API_PASSWORD=<auto-generated>
