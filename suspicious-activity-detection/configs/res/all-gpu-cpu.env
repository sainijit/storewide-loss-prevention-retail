DECODE='rtph264depay ! h264parse ! vah264dec ! vapostproc ! video/x-raw(memory:VAMemory)'
DETECT_DEVICE=GPU
PRE_PROCESS=pre-process-backend=va-surface-sharing
PRE_PROCESS_CONFIG=pre-process-config=resize_type=standard
DETECTION_OPTIONS="ie-config=GPU_THROUGHPUT_STREAMS=1 nireq=1"
REID_DEVICE=CPU
REID_PRE_PROCESS=pre-process-backend=opencv
REID_OPTIONS="nireq=2"
POST_DETECT='vapostproc ! video/x-raw'
POST_INFERENCE=""
QUEUE_OPTIONS='max-size-buffers=1 leaky=downstream'
DETECT_THRESHOLD=0.5
INFERENCE_INTERVAL=3